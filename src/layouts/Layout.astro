---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = "O Marceneiro Digital | Móveis Planejados de Alto Padrão", description = "Descubra o Método SIM e economize até 60% em móveis planejados com projeto técnico e projetos à prova de erros." } = Astro.props;

const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://www.omarceneirodigital.com.br/#business",
      "name": "O Marceneiro Digital",
      "url": "https://www.omarceneirodigital.com.br/",
      "logo": "https://www.omarceneirodigital.com.br/logo.png",
      "image": "https://www.omarceneirodigital.com.br/screen.png",
      "description": "Projeto técnico para móveis planejados direto de fábrica com economia de até 60%.",
      "telephone": "+5551996532525",
      "priceRange": "$$$",
      "knowsAbout": [
        "Móveis Planejados",
        "Projeto 3D",
        "SketchUp",
        "Hellomob",
        "Cortecloud",
        "Otimização de Corte",
        "Corte Otimizado",
        "Índice de Eficiência de Chapa",
        "CNC",
        "MDF",
        "Marcenaria Digital",
        "Método SIM",
        "Engenharia de Produção",
        "Instalação de Móveis"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Brasil",
        "addressCountry": {
          "@type": "Country",
          "name": "BR"
        }
      },
      "areaServed": {
        "@type": "Country",
        "name": "Brasil"
      }
    },
    {
      "@type": "Service",
      "@id": "https://www.omarceneirodigital.com.br/#service",
      "name": "Projeto Técnico de Móveis Planejados",
      "description": "Serviço de projeto técnico para móveis sob medida com otimização de corte e garantia de execução.",
      "areaServed": {
        "@type": "Country",
        "name": "Brasil"
      },
      "provider": {
        "@type": "Person",
        "@id": "https://www.omarceneirodigital.com.br/#person",
        "name": "Willian Scariott",
        "jobTitle": "Marceneiro Digital",
        "worksFor": {
          "@id": "https://www.omarceneirodigital.com.br/#business"
        }
      }
    }
  ]
};
---

<!DOCTYPE html>
<html class="dark" lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://www.omarceneirodigital.com.br" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.omarceneirodigital.com.br/" />
    <meta property="og:title" content="Willian | Marceneiro Digital - Especialista em Projetos" />
    <meta property="og:description" content="Descubra o Método SIM e economize até 60% em móveis planejados com projeto técnico e projetos à prova de erros." />
    <meta property="og:image" content="https://www.omarceneirodigital.com.br/Hero.webp" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://www.omarceneirodigital.com.br/" />
    <meta property="twitter:title" content="Willian | Marceneiro Digital - Especialista em Projetos" />
    <meta property="twitter:description" content="Descubra o Método SIM e economize até 60% em móveis planejados com projeto técnico e projetos à prova de erros." />
    <meta property="twitter:image" content="https://www.omarceneirodigital.com.br/Hero.webp" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    
    <!-- Google Analytics 4 -->
    <script is:inline src="https://www.googletagmanager.com/gtag/js?id=G-QQFCVXF57B"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-QQFCVXF57B');
    </script>
    
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </head>
  <body class="bg-[#0B0C10] text-white font-body selection:bg-[#FBB03B] selection:text-black">
    <slot />
  </body>
</html>
