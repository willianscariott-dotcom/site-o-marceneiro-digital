---
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 w-full z-50 bg-[#0B0C10]/70 backdrop-blur-md border-b border-white/5">
  <nav class="max-w-7xl mx-auto px-4 md:px-6 py-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-2 cursor-pointer hover:opacity-80 transition-opacity">
      <img src="/Logo O Marceneiro.png" alt="O Marceneiro Digital" class="h-10 md:h-12 w-auto" />
    </a>
    
    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-8 font-['Inter'] text-sm font-medium">
      <a class={`hover:text-[#ffd39b] transition-colors duration-300 ${currentPath === '/' ? 'text-[#fbb03b] border-b-2 border-[#fbb03b] pb-1' : 'text-white/70'}`} href="/">Início</a>
      <a class="text-white/70 hover:text-[#ffd39b] transition-colors duration-300" href="/#como-funciona">Como Funciona</a>
      <a class={`hover:text-[#ffd39b] transition-colors duration-300 ${currentPath.startsWith('/estudos-de-caso') ? 'text-[#fbb03b] border-b-2 border-[#fbb03b] pb-1' : 'text-white/70'}`} href="/estudos-de-caso/">Estudos de Caso</a>
      <a class={`hover:text-[#ffd39b] transition-colors duration-300 ${currentPath.startsWith('/blog') ? 'text-[#fbb03b] border-b-2 border-[#fbb03b] pb-1' : 'text-white/70'}`} href="/blog">Blog Técnico</a>
      <a class="text-[#FBB03B] hover:text-[#ffd39b] transition-colors duration-300 font-bold" href="/blog/guia-marcenaria-4-0">Guia Marcenaria 4.0</a>
      <a class={`hover:text-[#ffd39b] transition-colors duration-300 ${currentPath.startsWith('/guia-de-medicao') ? 'text-[#fbb03b] border-b-2 border-[#fbb03b] pb-1' : 'text-white/70'}`} href="/guia-de-medicao">Guia de Medição</a>
      <a class={`hover:text-[#ffd39b] transition-colors duration-300 ${currentPath.startsWith('/faq') ? 'text-[#fbb03b] border-b-2 border-[#fbb03b] pb-1' : 'text-white/70'}`} href="/faq">Dúvidas (FAQ)</a>
    </div>

    <!-- Desktop CTA -->
    <a id="btn-whatsapp-lead" href="https://wa.me/5551996532525?text=Ol%C3%A1%20Willian%21%20Quero%20garantir%20um%20projeto%20100%25%20execut%C3%A1vel%20no%20Cortecloud%2C%20com%20plano%20de%20corte%20otimizado%20e%20zero%20margem%20de%20erro." class="track-whatsapp hidden md:inline-flex bg-[#FBB03B] text-black px-6 py-2.5 font-label font-bold text-xs uppercase tracking-widest hover:bg-[#FBB03B]/90 transition-all active:scale-95 duration-300 rounded-md shadow-md hover:shadow-lg hover:-translate-y-0.5">
      Iniciar Meu Projeto
    </a>

    <!-- Mobile Hamburger Button -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col justify-center items-center gap-1.5 p-2 w-10 h-10" aria-label="Abrir menu">
      <span class="hamburger-line w-6 h-0.5 bg-white transition-transform duration-300"></span>
      <span class="hamburger-line w-6 h-0.5 bg-white transition-opacity duration-300"></span>
      <span class="hamburger-line w-6 h-0.5 bg-white transition-transform duration-300"></span>
    </button>
  </nav>

  <!-- Mobile Menu Sidebar -->
  <div id="mobile-menu" class="fixed top-0 right-0 h-screen w-72 max-w-[85vw] z-40 bg-[#0B0C10] md:hidden translate-x-full transition-transform duration-300">
    <div class="h-full flex flex-col overflow-y-auto">
      <!-- Header -->
      <div style="padding: 1rem; border-bottom: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center;">
        <img src="/Logo O Marceneiro.png" alt="O Marceneiro Digital" style="height: 2rem; width: auto;" />
        <button id="mobile-menu-close" style="background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; padding: 0.5rem; line-height: 1;">
          ×
        </button>
      </div>
      
      <!-- Links -->
      <div style="flex: 1; padding: 2rem 1.5rem; display: flex; flex-direction: column; gap: 0.5rem;">
        <a href="/" style={`display: block; color: ${currentPath === '/' ? '#FBB03B' : 'white'}; text-decoration: none; font-size: 1.25rem; font-weight: 500; font-family: 'Inter', sans-serif; padding: 1rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem;`}>Início</a>
        <a href="/#como-funciona" style="display: block; color: white; text-decoration: none; font-size: 1.25rem; font-weight: 500; font-family: 'Inter', sans-serif; padding: 1rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem;">Como Funciona</a>
        <a href="/estudos-de-caso/" style={`display: block; color: ${currentPath.startsWith('/estudos-de-caso') ? '#FBB03B' : 'white'}; text-decoration: none; font-size: 1.25rem; font-weight: 500; font-family: 'Inter', sans-serif; padding: 1rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem;`}>Estudos de Caso</a>
        <a href="/blog" style={`display: block; color: ${currentPath.startsWith('/blog') ? '#FBB03B' : 'white'}; text-decoration: none; font-size: 1.25rem; font-weight: 500; font-family: 'Inter', sans-serif; padding: 1rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem;`}>Blog Técnico</a>
        <a href="/blog/guia-marcenaria-4-0" style="display: block; color: #FBB03B; text-decoration: none; font-size: 1.25rem; font-weight: 600; font-family: 'Inter', sans-serif; padding: 1rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem;">Guia Marcenaria 4.0</a>
        <a href="/guia-de-medicao" style={`display: block; color: ${currentPath.startsWith('/guia-de-medicao') ? '#FBB03B' : 'white'}; text-decoration: none; font-size: 1.25rem; font-weight: 500; font-family: 'Inter', sans-serif; padding: 1rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem;`}>Guia de Medição</a>
        <a href="/faq" style={`display: block; color: ${currentPath.startsWith('/faq') ? '#FBB03B' : 'white'}; text-decoration: none; font-size: 1.25rem; font-weight: 500; font-family: 'Inter', sans-serif; padding: 1rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem;`}>Dúvidas (FAQ)</a>
      </div>
    </div>
  </div>
  
  <!-- Overlay -->
  <div id="mobile-menu-overlay" class="fixed inset-0 bg-black/50 z-30 md:hidden opacity-0 pointer-events-none transition-opacity duration-300"></div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-menu-overlay');
  const hamburgerLines = document.querySelectorAll('.hamburger-line');

  const openMenu = () => {
    mobileMenu.classList.remove('translate-x-full');
    overlay.classList.remove('opacity-0', 'pointer-events-none');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    mobileMenu.classList.add('translate-x-full');
    overlay.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  };

  menuBtn?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeMenu();
  });
</script>