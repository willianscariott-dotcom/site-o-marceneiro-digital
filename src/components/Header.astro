---
---
<header class="fixed top-0 w-full z-50 bg-[#0B0C10]/70 backdrop-blur-md border-b border-white/5">
  <nav class="max-w-7xl mx-auto px-4 md:px-6 py-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-2 cursor-pointer hover:opacity-80 transition-opacity">
      <img src="/Logo O Marceneiro.png" alt="O Marceneiro Digital" class="h-10 md:h-12 w-auto" />
    </a>
    
    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center gap-8 font-['Space_Grotesk'] text-sm font-medium">
      <a class="text-white/70 hover:text-[#ffd39b] transition-colors duration-300" href="/">Início</a>
      <a class="text-[#fbb03b] border-b-2 border-[#fbb03b] pb-1 hover:text-[#ffd39b] transition-colors duration-300" href="/#como-funciona">Como Funciona</a>
      <a class="text-white/70 hover:text-[#ffd39b] transition-colors duration-300" href="/estudos-de-caso/">Estudos de Caso</a>
      <a class="text-white/70 hover:text-[#ffd39b] transition-colors duration-300" href="/blog">Blog Técnico</a>
      <a class="text-white/70 hover:text-[#ffd39b] transition-colors duration-300" href="/guia-de-medicao">Guia de Medição</a>
      <a class="text-white/70 hover:text-[#ffd39b] transition-colors duration-300" href="/faq">Dúvidas (FAQ)</a>
    </div>

    <!-- Desktop CTA -->
    <a href="https://wa.me/5551996532525?text=Ol%C3%A1%20Willian%21%20Quero%20garantir%20um%20projeto%20100%25%20execut%C3%A1vel%20no%20Cortecloud%2C%20com%20plano%20de%20corte%20otimizado%20e%20zero%20margem%20de%20erro." class="hidden md:inline-flex bg-[#FBB03B] text-black px-6 py-2.5 font-label font-bold text-xs uppercase tracking-widest hover:bg-[#FBB03B]/90 transition-all active:scale-95 duration-300 rounded-md shadow-md hover:shadow-lg hover:-translate-y-0.5">
      Iniciar Meu Projeto
    </a>

    <!-- Mobile Hamburger Button -->
    <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Abrir menu">
      <span class="w-6 h-0.5 bg-white"></span>
      <span class="w-6 h-0.5 bg-white"></span>
      <span class="w-6 h-0.5 bg-white"></span>
    </button>
  </nav>

  <!-- Mobile Menu Full Screen -->
  <div id="mobile-menu" class="fixed inset-0 z-40 bg-black md:hidden" style="display: none;">
    <div class="h-full flex flex-col">
      <!-- Header -->
      <div style="padding: 1rem; border-bottom: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center;">
        <img src="/Logo O Marceneiro.png" alt="O Marceneiro Digital" style="height: 2rem; width: auto;" />
        <button id="mobile-menu-close" style="background: none; border: none; color: white; font-size: 1.5rem; cursor: pointer; padding: 0.5rem; line-height: 1;">
          ×
        </button>
      </div>
      
      <!-- Links -->
      <div style="flex: 1; overflow-y: auto; padding: 2rem 1.5rem;">
        <a href="/" style="display: block; color: white; text-decoration: none; font-size: 1.125rem; font-weight: 500; font-family: 'Space Grotesk', sans-serif; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.1);">Início</a>
        <a href="/#como-funciona" style="display: block; color: white; text-decoration: none; font-size: 1.125rem; font-weight: 500; font-family: 'Space Grotesk', sans-serif; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.1);">Como Funciona</a>
        <a href="/estudos-de-caso/" style="display: block; color: white; text-decoration: none; font-size: 1.125rem; font-weight: 500; font-family: 'Space Grotesk', sans-serif; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.1);">Estudos de Caso</a>
        <a href="/blog" style="display: block; color: white; text-decoration: none; font-size: 1.125rem; font-weight: 500; font-family: 'Space Grotesk', sans-serif; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.1);">Blog Técnico</a>
        <a href="/guia-de-medicao" style="display: block; color: white; text-decoration: none; font-size: 1.125rem; font-weight: 500; font-family: 'Space Grotesk', sans-serif; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.1);">Guia de Medição</a>
        <a href="/faq" style="display: block; color: white; text-decoration: none; font-size: 1.125rem; font-weight: 500; font-family: 'Space Grotesk', sans-serif; padding: 0.75rem 0; border-bottom: 1px solid rgba(255,255,255,0.1);">Dúvidas (FAQ)</a>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menuClose = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  menuBtn?.addEventListener('click', () => {
    mobileMenu.style.display = 'block';
    document.body.style.overflow = 'hidden';
  });

  const closeMenu = () => {
    mobileMenu.style.display = 'none';
    document.body.style.overflow = '';
  };

  menuClose?.addEventListener('click', closeMenu);

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>