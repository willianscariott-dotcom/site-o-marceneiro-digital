<footer class="w-full py-12 px-6 border-t border-white/5 bg-[#0B0C10]">
  <div class="flex flex-col md:flex-row justify-between items-start gap-8 max-w-7xl mx-auto">
    <div class="flex flex-col gap-4">
      <div class="flex items-center gap-2">
        <span class="material-symbols-outlined text-[#FBB03B]" data-icon="architecture">architecture</span>
        <span class="font-['Space_Grotesk'] font-bold text-[#FBB03B] uppercase tracking-widest">O Marceneiro Digital</span>
      </div>
      <p class="font-['Inter'] text-sm leading-relaxed text-white/50 max-w-xs">
        © 2026 O Marceneiro Digital. Todos os direitos reservados.
      </p>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-12">
      <div class="flex flex-col gap-4">
        <p class="font-label text-[10px] uppercase tracking-widest text-white/30">Navegação</p>
        <a class="text-white/50 text-sm hover:text-white transition-all" href="#">Como Funciona</a>
        <a class="text-white/50 text-sm hover:text-white transition-all" href="#">Estudos de Caso</a>
        <a class="text-white/50 text-sm hover:text-white transition-all" href="#">Blog Técnico</a>
        <a class="text-white/50 text-sm hover:text-white transition-all" href="#">Dúvidas (FAQ)</a>
      </div>
      <div class="flex flex-col gap-4">
        <p class="font-label text-[10px] uppercase tracking-widest text-white/30">Legal</p>
        <a class="text-white/50 text-sm hover:text-white transition-all" href="#">Privacidade</a>
        <a class="text-white/50 text-sm hover:text-white transition-all" href="#">Termos de Uso</a>
      </div>
      <div class="flex flex-col gap-4">
        <p class="font-label text-[10px] uppercase tracking-widest text-white/30">Social</p>
        <div class="flex gap-4">
          <a class="text-white/50 hover:text-[#FBB03B] transition-colors" href="#">
            <span class="material-symbols-outlined">share</span>
          </a>
          <a class="text-white/50 hover:text-[#FBB03B] transition-colors" href="#">
            <span class="material-symbols-outlined">video_library</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
