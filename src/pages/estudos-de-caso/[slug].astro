---
import Icon from '../../components/Icon.astro';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

import angelaCozinha from '../../assets/Portfolio/angela-cozinha-principal_11zon.webp';
import angelaGas from '../../assets/Portfolio/angela-gas-detail_11zon.webp';
import carina3d from '../../assets/Portfolio/Carina-3d.webp';
import carinaCorte from '../../assets/Portfolio/carina-corte.webp';

const imageMap = {
  '/Portfolio/angela-cozinha-principal_11zon.webp': angelaCozinha,
  '/Portfolio/angela-gas-detail_11zon.webp': angelaGas,
  '/Portfolio/Carina-3d.webp': carina3d,
  '/Portfolio/carina-corte.webp': carinaCorte,
};

export async function getStaticPaths() {
  const entries = await getCollection('estudos-de-caso');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const coverImage = imageMap[entry.data.cover_image];
const cortecloudImage = imageMap[entry.data.cortecloud_image];

const seoKeywords = entry.data.seo_keywords || ['SketchUp', 'Método SIM', 'Otimização de Espaço', 'Móveis Planejados'];
const schemaData = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": entry.data.title,
  "description": entry.data.challenge,
  "proficiencyLevel": "Expert",
  "about": seoKeywords.map(keyword => ({
    "@type": "Thing",
    "name": keyword,
    "description": `Técnicas de ${keyword} para móveis planejados`
  })),
  "keywords": seoKeywords.join(", "),
  "genre": "Case Study",
  "proficiencyLevel": "Expert",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": entry.data.efficiency_iec.toString(),
    "bestRating": "100",
    "worstRating": "0",
    "ratingCount": "1"
  },
  "provider": {
    "@type": "LocalBusiness",
    "name": "O Marceneiro Digital",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": entry.data.location.split(', ')[0],
      "addressRegion": entry.data.location.split(', ')[1] || "BR",
      "addressCountry": "BR"
    }
  },
  "productSupported": {
    "@type": "Product",
    "name": entry.data.client,
    "description": entry.data.challenge
  }
};

const currentUrl = Astro.site 
  ? `${Astro.site}estudos-de-caso/${entry.id}`
  : `https://www.omarceneirodigital.com.br/estudos-de-caso/${entry.id}`;
---

<Layout title={`${entry.data.title} | Estudo de Caso`}>
  <Header />
  <article class="min-h-screen pt-20">
    <div class="max-w-7xl mx-auto px-6 py-12">
      <header class="mb-12">
        <p class="text-[#FBB03B] text-sm font-medium mb-2 tracking-wider uppercase">Estudo de Caso</p>
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">{entry.data.title}</h1>
        
        <div class="flex flex-wrap gap-4 text-gray-400 text-sm">
          <span class="flex items-center gap-2">
            <Icon name="person" class="text-[#FBB03B]" />
            {entry.data.client}
          </span>
          <span class="flex items-center gap-2">
            <Icon name="location_on" class="text-[#FBB03B]" />
            {entry.data.location}
          </span>
          <span class="flex items-center gap-2">
            <Icon name="payments" class="text-[#FBB03B]" />
            {entry.data.investment}
          </span>
        </div>
      </header>

      <div class="grid md:grid-cols-2 gap-6 mb-12">
        <div class="relative aspect-video rounded-xl overflow-hidden">
          {coverImage && (
            <Image 
              src={coverImage} 
              alt={`Design do projeto ${entry.data.title}`}
              width={1200}
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
          )}
          <div class="absolute bottom-4 left-4 bg-black/70 backdrop-blur-sm px-3 py-1.5 rounded-lg">
            <span class="text-xs font-medium text-[#FBB03B] uppercase tracking-wider">Design</span>
          </div>
        </div>
        <div class="relative aspect-video rounded-xl overflow-hidden">
          {cortecloudImage && (
            <Image 
              src={cortecloudImage} 
              alt={entry.data.secondary_label ? `${entry.data.secondary_label} - ${entry.data.title}` : `Engenharia de produção - ${entry.data.title}`}
              width={1200}
              class="w-full h-full object-cover"
              loading="lazy"
              decoding="async"
            />
          )}
          <div class="absolute bottom-4 left-4 bg-black/70 backdrop-blur-sm px-3 py-1.5 rounded-lg">
            <span class="text-xs font-medium text-[#FBB03B] uppercase tracking-wider">{entry.data.secondary_label || 'Engenharia de Produção'}</span>
          </div>
        </div>
      </div>

      <div class="bg-[#1A1D23] rounded-2xl p-6 mb-12 border border-[#2A2D33]">
        <h2 class="text-lg font-semibold mb-3 text-[#FBB03B]">Desafio</h2>
        <p class="text-gray-300 leading-relaxed">{entry.data.challenge}</p>
        <div class="mt-6 pt-6 border-t border-[#2A2D33]">
          <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-lg bg-[#FBB03B]/10 flex items-center justify-center">
              <span class="text-2xl font-bold text-[#FBB03B]">{entry.data.efficiency_iec}%</span>
            </div>
            <div>
              <p class="text-sm text-gray-400">Índice de Eficiência de Corte (IEC)</p>
              <p class="text-xs text-gray-500">Metodologia SIM - Sistema Inteligente de Marcenaria</p>
            </div>
          </div>
        </div>
      </div>

      <div class="content-case mt-12 space-y-6">
        <Content />
      </div>

      <div class="mt-16 p-8 bg-gradient-to-br from-[#1A1D23] to-[#0B0C10] rounded-2xl border border-[#FBB03B]/20 text-center">
        <p class="text-lg md:text-xl font-medium text-white mb-6 max-w-2xl mx-auto">
          Quer garantir um projeto 100% executável no Cortecloud, com plano de corte otimizado e zero margem de erro na montagem? Fale comigo no WhatsApp.
        </p>
<a id="btn-whatsapp-lead" href="https://wa.me/5551996532525?text=Ol%C3%A1%20Willian%21%20Quero%20um%20Projeto%20Inteligente%20para%20o%20meu%20Espa%C3%A7o%21" class="track-whatsapp inline-flex items-center gap-3 bg-[#FBB03B] text-black px-8 py-4 font-bold text-lg rounded-lg hover:bg-[#FBB03B]/90 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
            <Icon name="chat" class="text-2xl" />
            Quero um Projeto Inteligente para o meu Espaço
          </a>
      </div>
    </div>
  </article>
  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
</Layout>