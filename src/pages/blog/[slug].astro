---
import Icon from '../../components/Icon.astro';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

import dosssie1 from '../../assets/Portfolio/dossie-1.webp';
import dosssie2 from '../../assets/Portfolio/dossie-2.webp';
import dosssie3 from '../../assets/Portfolio/dossie-3.webp';
import dosssie4 from '../../assets/Portfolio/dossie-4.webp';
import dosssie5 from '../../assets/Portfolio/dossie-5.webp';
import dosssie6 from '../../assets/Portfolio/dossie-6.webp';

const dosssieImages = [dosssie1, dosssie2, dosssie3, dosssie4, dosssie5, dosssie6];

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const hasVideo = entry.data.video_id;
const coverImage = hasVideo 
  ? `https://img.youtube.com/vi/${entry.data.video_id}/maxresdefault.jpg`
  : entry.data.cover_image;

const articleSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ImageObject",
      "url": coverImage ? new URL(coverImage, Astro.site).toString() : undefined,
      "description": entry.data.excerpt
    },
    {
      "@type": "TechArticle",
      "headline": entry.data.title,
      "description": entry.data.excerpt,
      "image": coverImage ? new URL(coverImage, Astro.site).toString() : undefined,
      "author": {
        "@type": "Person",
        "name": "Willian Scariott",
        "knowsAbout": ["Cortecloud", "Marcenaria 4.0", "Hellomob"]
      },
      "datePublished": entry.data.date.toISOString(),
      "publisher": {
        "@type": "LocalBusiness",
        "name": "O Marceneiro Digital"
      },
      "about": ["Marcenaria 4.0", "CNC", "Método SIM"]
    },
    {
      "@type": "Article",
      "headline": entry.data.title,
      "description": entry.data.excerpt,
      "image": coverImage ? new URL(coverImage, Astro.site).toString() : undefined,
      "author": {
        "@type": "Person",
        "name": "Willian Scariott",
        "url": "https://www.omarceneirodigital.com.br",
        "knowsAbout": ["Cortecloud", "Marcenaria 4.0", "Hellomob"]
      },
      "datePublished": entry.data.date.toISOString(),
      "publisher": {
        "@type": "LocalBusiness",
        "name": "O Marceneiro Digital"
      }
    }
  ]
};

const videoSchema = hasVideo ? {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": entry.data.video_title,
  "description": entry.data.video_description,
  "thumbnailUrl": [`https://img.youtube.com/vi/${entry.data.video_id}/maxresdefault.jpg`],
  "uploadDate": entry.data.date.toISOString(),
  "duration": "PT5M30S",
  "contentUrl": `https://www.youtube.com/watch?v=${entry.data.video_id}`,
  "embedUrl": `https://www.youtube.com/embed/${entry.data.video_id}`,
  "publisher": {
    "@type": "Organization",
    "name": "O Marceneiro Digital",
    "logo": {
      "@type": "ImageObject",
      "url": "https://www.omarceneirodigital.com.br/logo.png"
    }
  }
} : null;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Qualquer pessoa sem experiência pode fazer um projeto no Cortecloud?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Até é possível tentar desenhar algo básico, mas o risco é gigante. O problema não é desenhar, é calcular os descontos de fita de borda, o desnível do teto/piso e o recuo para dobradiças. Um erro de 2mm na plataforma significa que a sua chapa inteira irá para o lixo. O Método SIM entra exatamente para blindar o seu dinheiro contra esses erros de amadores."
      }
    },
    {
      "@type": "Question",
      "name": "Por que algumas centrais de serviço demoram a dar orçamento ou tratam mal clientes leigos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Centrais de usinagem ganham dinheiro com velocidade. Quando um cliente envia um projeto amador cheio de erros ou faltando peças, a central perde horas tentando corrigir. Quando envio um projeto pelo Método SIM, o arquivo chega validado, parametrizado e 'pronto para corte'. É por isso que nossos orçamentos são liberados instantaneamente e com valores exatos."
      }
    },
    {
      "@type": "Question",
      "name": "O orçamento do Cortecloud já inclui as chapas de MDF?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende da configuração e da central! Muitos clientes geram orçamentos e tomam um susto depois porque o valor estava calculando apenas o serviço de corte, sem a chapa. Na minha auditoria técnica, eu gero o orçamento final unificando o custo da chapa, das fitas de borda e da usinagem, com 100% de transparência."
      }
    }
  ]
};

const isDossieArticle = entry.id === 'dossie-de-montagem';
---

<Layout title={`${entry.data.title} | Blog Técnico`} description={entry.data.excerpt}>
  <Header />
  <article class="min-h-screen pt-20 bg-[#0B0C10]">
    <div class="max-w-4xl mx-auto px-6 py-12">
      <header class="mb-12 text-center">
        <p class="text-[#FBB03B] text-sm font-medium mb-2 tracking-wider uppercase">
          {entry.data.date.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{entry.data.title}</h1>
        <p class="text-gray-400 max-w-2xl mx-auto">{entry.data.excerpt}</p>
        <div class="mt-4 flex items-center justify-center gap-2 text-sm text-gray-500">
          <Icon name="person" class="text-[#FBB03B] text-sm" />
          <span>Por {entry.data.author}</span>
        </div>
      </header>

      {isDossieArticle && (
        <div class="mb-8">
          <div class="relative w-full rounded-xl overflow-hidden bg-[#1A1D23]" style="min-height: 400px;">
            <div class="flex transition-transform duration-500 h-full" id="carousel">
              <div class="min-w-full p-2 md:p-4 flex items-center justify-center">
                <button class="lightbox-trigger" data-img="0">
                  <Image src={dosssieImages[0]} alt="Vista explodida de móvel" width={1200} class="max-w-full max-h-[300px] md:max-h-[500px] object-contain rounded-lg" loading="eager" decoding="async" />
                </button>
              </div>
              <div class="min-w-full p-2 md:p-4 flex items-center justify-center">
                <button class="lightbox-trigger" data-img="1">
                  <Image src={dosssieImages[1]} alt="Plano de furação Cortecloud" width={1200} class="max-w-full max-h-[300px] md:max-h-[500px] object-contain rounded-lg" loading="lazy" decoding="async" />
                </button>
              </div>
              <div class="min-w-full p-2 md:p-4 flex items-center justify-center">
                <button class="lightbox-trigger" data-img="2">
                  <Image src={dosssieImages[2]} alt="Detalhamento de ferragens" width={1200} class="max-w-full max-h-[300px] md:max-h-[500px] object-contain rounded-lg" loading="lazy" decoding="async" />
                </button>
              </div>
              <div class="min-w-full p-2 md:p-4 flex items-center justify-center">
                <button class="lightbox-trigger" data-img="3">
                  <Image src={dosssieImages[3]} alt="Lista de ferragens" width={1200} class="max-w-full max-h-[300px] md:max-h-[500px] object-contain rounded-lg" loading="lazy" decoding="async" />
                </button>
              </div>
              <div class="min-w-full p-2 md:p-4 flex items-center justify-center">
                <button class="lightbox-trigger" data-img="4">
                  <Image src={dosssieImages[4]} alt="Folgas de ajuste" width={1200} class="max-w-full max-h-[300px] md:max-h-[500px] object-contain rounded-lg" loading="lazy" decoding="async" />
                </button>
              </div>
              <div class="min-w-full p-2 md:p-4 flex items-center justify-center">
                <button class="lightbox-trigger" data-img="5">
                  <Image src={dosssieImages[5]} alt="Projeto finalizado" width={1200} class="max-w-full max-h-[300px] md:max-h-[500px] object-contain rounded-lg" loading="lazy" decoding="async" />
                </button>
              </div>
            </div>
            <button id="prev-btn" class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/60 hover:bg-black/80 text-white p-3 rounded-full transition-colors z-10">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            </button>
            <button id="next-btn" class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/60 hover:bg-black/80 text-white p-3 rounded-full transition-colors z-10">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </button>
            <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2" id="carousel-dots"></div>
          </div>
          <p class="text-center text-gray-500 text-sm mt-2">Toque nas imagens para ampliar</p>
        </div>
      )}

      {/* Cover image shown for articles with custom cover - otherwise thumbnail shown via og:image from JSON-LD */}

      {entry.data.cover_image && (
        <div class="mb-12 rounded-2xl overflow-hidden">
          <img 
            src={entry.data.cover_image} 
            alt={entry.data.cover_alt || entry.data.title}
            class="w-full aspect-video object-cover"
          />
        </div>
      )}

      <div class="content-case space-y-6">
        <Content />
      </div>

      {isDossieArticle && (
        <div class="flex flex-col sm:flex-row gap-4 mt-12">
          <a href="/dossie-exemplo.pdf" download class="flex-1 bg-[#FBB03B] text-black px-6 py-4 font-bold text-center rounded-lg hover:bg-[#FBB03B]/90 transition-all">
            Baixe um Exemplo Real do Dossiê Técnico em PDF
          </a>
          <a id="btn-whatsapp-lead" href="https://wa.me/5551996532525?text=Ol%C3%A1%20Willian%21%20Quero%20saber%20mais%20sobre%20o%20Dossi%C3%AA%20T%C3%A9cnico%20do%20M%C3%A9todo%20SIM" class="track-whatsapp flex-1 border-2 border-[#FBB03B] text-[#FBB03B] px-6 py-4 font-bold text-center rounded-lg hover:bg-[#FBB03B]/10 transition-all">
            Falar com o Especialista no WhatsApp
          </a>
        </div>
      )}

      {!isDossieArticle && (
        <div class="mt-16 p-8 bg-gradient-to-br from-[#1A1D23] to-[#0B0C10] rounded-2xl border border-[#FBB03B]/20 text-center">
          <p class="text-lg md:text-xl font-medium text-white mb-6 max-w-2xl mx-auto">
            Transforme o seu projeto 3D em um dossiê pronto para a fábrica e garanta a qualidade industrial do seu móvel.
          </p>
          <a id="btn-whatsapp-lead" href="https://wa.me/5551996532525?text=Ol%C3%A1%20Willian%21%20Quero%20meu%20projeto%20no%20M%C3%A9todo%20SIM" class="track-whatsapp inline-flex items-center gap-3 bg-[#FBB03B] text-black px-8 py-4 font-bold text-lg rounded-lg hover:bg-[#FBB03B]/90 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
            <Icon name="chat" class="text-2xl" />
            Quero meu projeto no Método SIM
          </a>
        </div>
      )}

      <div class="mt-8 pt-8 border-t border-[#2A2D33]">
        <a href="/blog" class="inline-flex items-center gap-2 text-[#FBB03B] hover:text-[#ffd39b] transition-colors">
          <Icon name="arrow_back" class="text-sm" />
          Voltar para o Blog
        </a>
      </div>
    </div>
  </article>
  <Footer />

  {isDossieArticle && (
    <script>
      const carousel = document.getElementById('carousel');
      const prevBtn = document.getElementById('prev-btn');
      const nextBtn = document.getElementById('next-btn');
      const dotsContainer = document.getElementById('carousel-dots');
      const totalSlides = 6;
      let currentSlide = 0;

      for (let i = 0; i < totalSlides; i++) {
        const dot = document.createElement('button');
        dot.className = 'w-2 h-2 rounded-full bg-white/50 hover:bg-white transition-colors';
        dot.addEventListener('click', () => goToSlide(i));
        dotsContainer.appendChild(dot);
      }

      const dots = dotsContainer.querySelectorAll('button');

      function updateDots() {
        dots.forEach((dot, index) => {
          dot.classList.toggle('bg-white', index === currentSlide);
          dot.classList.toggle('bg-white/50', index !== currentSlide);
        });
      }

      function goToSlide(index) {
        currentSlide = index;
        carousel.style.transform = `translateX(-${currentSlide * 100}%)`;
        updateDots();
      }

      prevBtn?.addEventListener('click', () => {
        currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
        goToSlide(currentSlide);
      });

      nextBtn?.addEventListener('click', () => {
        currentSlide = (currentSlide + 1) % totalSlides;
        goToSlide(currentSlide);
      });

      updateDots();

      // Lightbox functionality
      const lightboxTriggers = document.querySelectorAll('.lightbox-trigger');
      const lightbox = document.createElement('div');
      lightbox.id = 'lightbox';
      lightbox.className = 'fixed inset-0 z-50 bg-black/95 hidden items-center justify-center';
      lightbox.innerHTML = `
        <button id="lightbox-close" class="absolute top-4 right-4 text-white text-3xl hover:text-[#FBB03B] transition-colors z-50">&times;</button>
        <button id="lightbox-prev" class="absolute left-2 md:left-4 top-1/2 -translate-y-1/2 text-white hover:text-[#FBB03B] transition-colors p-4 text-4xl">&lsaquo;</button>
        <button id="lightbox-next" class="absolute right-2 md:right-4 top-1/2 -translate-y-1/2 text-white hover:text-[#FBB03B] transition-colors p-4 text-4xl">&rsaquo;</button>
        <img id="lightbox-img" class="max-w-[95vw] max-h-[90vh] object-contain" />
      `;
      document.body.appendChild(lightbox);

      const lightboxImg = document.getElementById('lightbox-img');
      const lightboxClose = document.getElementById('lightbox-close');
      const lightboxPrev = document.getElementById('lightbox-prev');
      const lightboxNext = document.getElementById('lightbox-next');
      let currentLightboxIndex = 0;

      const openLightbox = (index) => {
        currentLightboxIndex = index;
        const img = dosssieImages[index].src;
        lightboxImg.src = img;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      };

      const closeLightbox = () => {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        document.body.style.overflow = '';
      };

      lightboxTriggers.forEach((trigger, index) => {
        trigger.addEventListener('click', () => openLightbox(index));
      });

      lightboxClose?.addEventListener('click', closeLightbox);
      lightboxPrev?.addEventListener('click', () => {
        currentLightboxIndex = (currentLightboxIndex - 1 + dosssieImages.length) % dosssieImages.length;
        openLightbox(currentLightboxIndex);
      });
      lightboxNext?.addEventListener('click', () => {
        currentLightboxIndex = (currentLightboxIndex + 1) % dosssieImages.length;
        openLightbox(currentLightboxIndex);
      });

      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowLeft') currentLightboxIndex = (currentLightboxIndex - 1 + dosssieImages.length) % dosssieImages.length;
        if (e.key === 'ArrowRight') currentLightboxIndex = (currentLightboxIndex + 1) % dosssieImages.length;
      });
    </script>
  )}

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {videoSchema && <script type="application/ld+json" set:html={JSON.stringify(videoSchema)} />}
  {isDossieArticle && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</Layout>