---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TrustedBy from '../components/TrustedBy.astro';
import FeaturesBento from '../components/FeaturesBento.astro';
import Journey from '../components/Journey.astro';
import Metrics from '../components/Metrics.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />
  <main class="pt-16 md:pt-24 overflow-x-hidden">
    <Hero />
    <TrustedBy />
    <FeaturesBento />
    <Journey />
    <Metrics />
    <Testimonials />
    <CTA />
  </main>
  <Footer />
</Layout>
